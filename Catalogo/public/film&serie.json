      {
        "id": "tt0004860",
        "type": "movie",
        "primaryTitle": "The Adventures of a Madcap",
        "originalTitle": "The Adventures of a Madcap",
        "primaryImage": {
          "url": "https://m.media-amazon.com/images/M/MV5BMmFiOWEyYTYtYTMxNC00NzY3LTkzNjYtMjZhNGUyNTRkODUxXkEyXkFqcGc@._V1_.jpg",
          "width": 1289,
